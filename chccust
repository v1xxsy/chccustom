  local hl=mkL(c1,T("hint_fly"),0,0,0,16,10,SUBTEXT,false) hl.LayoutOrder=7
  local hl2=mkL(c1,T("hint_modeswitch"),0,0,0,16,10,SUBTEXT,false) hl2.LayoutOrder=8

  local function enableH1m(on)
    h1mFlyOn=on
    if on then
      lastFlyType="h1m"
      if pr1FlyOn then pr1SetOn(false,true) pr1FlyOn=false if pr1FlyConn then pr1FlyConn:Disconnect() pr1FlyConn=nil end pr1StatusL.Text=T("fly_off") pr1StatusL.TextColor3=RED_COL end
      local function flyStep() local char=LP.Character if not char then return end local hrp=char:FindFirstChild("HumanoidRootPart") if not hrp then return end local mv=Vector3.zero if UIS:IsKeyDown(Enum.KeyCode.W) then mv+=Cam.CFrame.LookVector end if UIS:IsKeyDown(Enum.KeyCode.S) then mv-=Cam.CFrame.LookVector end if UIS:IsKeyDown(Enum.KeyCode.A) then mv-=Cam.CFrame.RightVector end if UIS:IsKeyDown(Enum.KeyCode.D) then mv+=Cam.CFrame.RightVector end if UIS:IsKeyDown(Enum.KeyCode.Space) then mv+=Vector3.new(0,1,0) end local spd=UIS:IsKeyDown(Enum.KeyCode.LeftControl) and flyBoost or flySpeed hrp.Velocity=mv*spd hrp.CFrame=CFrame.lookAt(hrp.Position,hrp.Position+Cam.CFrame.LookVector) end
      if h1mFlyConn then h1mFlyConn:Disconnect() end h1mFlyConn=RS.Heartbeat:Connect(flyStep)
      playSound("on") notify("Luna","h1moza Fly ON",2) h1mStatusL.Text=T("fly_on") h1mStatusL.TextColor3=GREEN
    else
      if h1mFlyConn then h1mFlyConn:Disconnect() h1mFlyConn=nil end
      playSound("off") notify("Luna","h1moza Fly OFF",2) h1mStatusL.Text=T("fly_off") h1mStatusL.TextColor3=RED_COL
    end
