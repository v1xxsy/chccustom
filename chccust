  local function isAlly(plr)
    if not teamCheckEnabled then return false end
    local mt=LP.Team local tt=plr.Team
    return mt~=nil and tt~=nil and mt==tt
  end

  local function cleanBuiltinESP()
    for _,h in pairs(espHighlights) do pcall(function() if h and h.Parent then h:Destroy() end end) end
    for _,b in pairs(espBillboards) do pcall(function() if b and b.Parent then b:Destroy() end end) end
    espHighlights={} espBillboards={}
  end

  -- CONSTANT RenderStepped rendering — no toggling/interval
  local function updateBuiltinESP()
    if not builtinESPOn then return end
    -- Prune removed/left players
    for plr,_ in pairs(espHighlights) do
      if not plr.Parent or not plr.Character then
        pcall(function() if espHighlights[plr] and espHighlights[plr].Parent then espHighlights[plr]:Destroy() end end)
        pcall(function() if espBillboards[plr] and espBillboards[plr].Parent then espBillboards[plr]:Destroy() end end)
        espHighlights[plr]=nil espBillboards[plr]=nil
      end
    end
    -- Add new / update existing
    for _,plr in pairs(Plrs:GetPlayers()) do
      if plr~=LP and plr.Character then
        if isAlly(plr) then
          if espHighlights[plr] then pcall(function() espHighlights[plr]:Destroy() end) espHighlights[plr]=nil end
          if espBillboards[plr] then pcall(function() espBillboards[plr]:Destroy() end) espBillboards[plr]=nil end
        else
          local char=plr.Character
          -- Highlight: create once, let Roblox keep it rendered
          if not espHighlights[plr] or not espHighlights[plr].Parent then
            pcall(function()
              local hl=Instance.new("Highlight")
              hl.Parent=char
              hl.FillColor=Color3.fromRGB(255,40,40)
              hl.FillTransparency=espFillTransparency
              hl.OutlineColor=Color3.fromRGB(255,255,255)
              hl.OutlineTransparency=0
              hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
              hl.Enabled=true
              espHighlights[plr]=hl
            end)
          else
            -- Ensure it stays enabled every frame
            pcall(function()
              if espHighlights[plr] and espHighlights[plr].Parent then
                espHighlights[plr].Enabled=true
              end
            end)
          end
          -- Billboard name tag
          local hrp=char:FindFirstChild("HumanoidRootPart")
          if hrp and (not espBillboards[plr] or not espBillboards[plr].Parent) then
            pcall(function()
              local bb=Instance.new("BillboardGui")
              bb.Parent=hrp bb.Name="luna_esp_bb"
              bb.Size=UDim2.new(0,120,0,40)
              bb.StudsOffset=Vector3.new(0,3.4,0)
              bb.AlwaysOnTop=true bb.ResetOnSpawn=false
              local lbl=Instance.new("TextLabel")
              lbl.Parent=bb lbl.Size=UDim2.new(1,0,1,0)
              lbl.BackgroundTransparency=1
              lbl.Text=plr.Name
              lbl.TextColor3=Color3.fromRGB(255,255,255)
              lbl.Font=Enum.Font.GothamBold lbl.TextSize=espNameSize
              lbl.TextStrokeTransparency=0 lbl.TextStrokeColor3=Color3.fromRGB(0,0,0)
              lbl.ZIndex=2
              espBillboards[plr]=bb
            end)
          end
        end
      end
    end
  end

  -- Use RenderStepped for constant per-frame rendering
  RS.RenderStepped:Connect(function()
    pcall(updateBuiltinESP)
  end)

