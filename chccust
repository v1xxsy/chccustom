-- GAME LOGIC
-- ==============================
local csKD={{Enum.KeyCode.W,1},{Enum.KeyCode.S,-1}}
local function getDir(k) for _,v in next,csKD do if v[1]==k.KeyCode then return v[2] end end end
RS.Heartbeat:Connect(function()
  if not carSpeedEnabled then return end
  local veh=workspace:FindFirstChild("Vehicles") if not veh then return end
  for _,v in next,veh:GetChildren() do
    if v.Name~="Heli" then
      local eng=v:FindFirstChild("Engine") if eng then
        local bf=eng:FindFirstChild("NewForce") local cf=v:GetPrimaryPartCFrame().lookVector
        if not bf then bf=eng:FindFirstChild("BodyForce") or eng:FindFirstChild("VectorForce") if bf then bf=bf:Clone() bf.Parent=eng bf.Name="NewForce" end end
        if bf then local fa=1 if v.Name:lower():find("bike") then fa=0.3 elseif v.Name:lower():find("bugg") then fa=0.5 end
          local seat=v:FindFirstChild("Seat") if seat and seat:FindFirstChild("PlayerName") and seat.PlayerName.Value~=LP.Name then fa=0 end
          bf.Force=Vector3.new(cf.X*carSpeedVal*carSpeedDir*fa,0,cf.Z*carSpeedVal*carSpeedDir*fa) end end end end end)

RS.RenderStepped:Connect(function()
  pcall(function()
    for _,plr in pairs(Plrs:GetPlayers()) do
      if plr~=LP and plr.Character then
        local hrp=plr.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
          if hitboxEnabled then
            local isEnemy=true
            if teamCheckEnabled then local mt=LP.Team local tt=plr.Team if mt~=nil and tt~=nil and mt==tt then isEnemy=false end end
            if isEnemy then hrp.Size=Vector3.new(hitboxSize,hitboxSize,hitboxSize) hrp.Transparency=hitboxTrans hrp.Material=Enum.Material.Neon hrp.Color=hitboxColor hrp.CanCollide=false
            else hrp.Size=Vector3.new(2,2,1) hrp.Transparency=1 hrp.Material=Enum.Material.SmoothPlastic end
          else hrp.Size=Vector3.new(2,2,1) hrp.Transparency=1 hrp.Material=Enum.Material.SmoothPlastic end end end end end) end)

