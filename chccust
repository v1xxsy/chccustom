  local pr1Vel=Vector3.new(0,0,0)
  local SpeedKeyMult=5 local FlightSpeed=300 local FlightAcc=5 local TurnSpd=14
  local pr1Char,pr1HRP=nil,nil
  local function pr1SetChar(c) pr1Char=c pr1HRP=c and c:WaitForChild("HumanoidRootPart") or nil end
  LP.CharacterAdded:Connect(pr1SetChar) if LP.Character then pr1SetChar(LP.Character) end
  local function enablePr1(on)
    pr1FlyOn=on
    if on then
      lastFlyType="pr1"
      if h1mFlyOn then h1mSetOn(false,true) h1mFlyOn=false if h1mFlyConn then h1mFlyConn:Disconnect() h1mFlyConn=nil end h1mStatusL.Text=T("fly_off") h1mStatusL.TextColor3=RED_COL end
      if pr1FlyConn then pr1FlyConn:Disconnect() end
      pr1Vel=pr1HRP and pr1HRP.Velocity or Vector3.new(0,0,0)
      pr1FlyConn=RS.Heartbeat:Connect(function(dt)
        if not pr1HRP then return end
        local base=Vector3.new(0,0,0)
        if not UIS:GetFocusedTextBox() then
          if UIS:IsKeyDown(Enum.KeyCode.W) then base=base+(Cam.CFrame.LookVector*FlightSpeed) end
          if UIS:IsKeyDown(Enum.KeyCode.A) then base=base-(Cam.CFrame.RightVector*FlightSpeed) end
          if UIS:IsKeyDown(Enum.KeyCode.S) then base=base-(Cam.CFrame.LookVector*FlightSpeed) end
          if UIS:IsKeyDown(Enum.KeyCode.D) then base=base+(Cam.CFrame.RightVector*FlightSpeed) end
          if UIS:IsKeyDown(Enum.KeyCode.Space) then base=base+(Cam.CFrame.UpVector*FlightSpeed) end
          if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then base=base*SpeedKeyMult end
        end
        local car=pcall(function() return pr1HRP:GetRootPart() end) and pr1HRP:GetRootPart() or pr1HRP
        pcall(function()
          if car.Anchored then return end
          pr1Vel=pr1Vel:Lerp(base,math.clamp(dt*FlightAcc,0,1))
          car.Velocity=pr1Vel+Vector3.new(0,2,0)
          if car~=pr1HRP then
            car.RotVelocity=Vector3.new(0,0,0)
            car.CFrame=car.CFrame:Lerp(CFrame.lookAt(car.Position,car.Position+pr1Vel+Cam.CFrame.LookVector),math.clamp(dt*TurnSpd,0,1))
          end
        end)
      end)
      playSound("on") notify("Luna","pr1p1zdnyt Fly ON",2) pr1StatusL.Text=T("fly_on") pr1StatusL.TextColor3=GREEN
    else
      if pr1FlyConn then pr1FlyConn:Disconnect() pr1FlyConn=nil end
      playSound("off") notify("Luna","pr1p1zdnyt Fly OFF",2) pr1StatusL.Text=T("fly_off") pr1StatusL.TextColor3=RED_COL
    end
    saveState()
  end
  pr1Btn.MouseButton1Click:Connect(function() pr1SetOn(not pr1GetOn()) enablePr1(pr1GetOn()) end)
  pr1OnCh(function(v) enablePr1(v) end)

  _switchFlyMode=function()
    local wasOn=h1mFlyOn or pr1FlyOn
    if lastFlyType~="pr1" then
      if h1mFlyOn then h1mSetOn(false,true) enableH1m(false) end
      lastFlyType="pr1"
      if wasOn then pr1SetOn(true,false) end
      notify("Fly Mode","pr1p1zdnyt",2)
    else
      if pr1FlyOn then pr1SetOn(false,true) enablePr1(false) end
      lastFlyType="h1m"
      if wasOn then h1mSetOn(true,false) end
      notify("Fly Mode","h1moza",2)
    end
  end

  _toggleFly=function()
    if lastFlyType=="pr1" then pr1SetOn(not pr1FlyOn) else h1mSetOn(not h1mFlyOn) end
  end

  mkSec(FlyPage,"sec_cs",9)
