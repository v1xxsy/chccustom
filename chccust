local function applyAspectRatio(ratioVal)
  currentAspect=ratioVal
  pcall(function()
    if not ratioVal then
      Cam.FieldOfView=baseFOV
    else
      local vp=Cam.ViewportSize
      local nativeRatio=(vp.X/math.max(vp.Y,1))
      local hFOV=2*math.atan(math.tan(math.rad(baseFOV)/2)*nativeRatio)
      local newVFOV=2*math.atan(math.tan(hFOV/2)/ratioVal)
      Cam.FieldOfView=math.clamp(math.deg(newVFOV),10,120)
    end
  end)
  saveState()
end

