local currentThemeName="Default"
local function writeThemesJSON(selected)
  pcall(function()
    if not isfolder("7yd7") then makefolder("7yd7") end
    local t={Themes={},Order={},Selected=selected or currentThemeName}
    for k,v in pairs(EMOTE_THEMES) do
      if k~="Default" then table.insert(t.Order,k) t.Themes[k]=v.data end
    end
    writefile("7yd7/EmoteThemes.json",HS:JSONEncode(t))
  end)
end
local function applyEmoteTheme(n)
  currentThemeName=n writeThemesJSON(n)
  local entry=EMOTE_THEMES[n] or EMOTE_THEMES["Default"]
  pcall(function()
    local env=getgenv() writeThemesJSON(n)
    if env.Config then env.Config.SelectedTheme=n end
    local function doApply()
      if env.ApplyTheme then
        local data=entry.data or nil
        if n=="Default" or (not data or not data.Background) then env.ApplyTheme(nil) else env.ApplyTheme(data) end
        return true
      end
      return false
    end
    if not doApply() then task.spawn(function() task.wait(1) doApply() task.wait(2) doApply() end) end
  end)
end

